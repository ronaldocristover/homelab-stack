# ============================================
# Monitoring Stack Configuration
# Copy to .env and fill in values
# ============================================

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# --- Loki ---
LOKI_PORT=3100
LOKI_RETENTION_HOURS=360  # 15 days

# --- Alertmanager ---
ALERTMANAGER_PORT=9093

# --- Exporters ---
CADVISOR_PORT=8081
NODE_EXPORTER_PORT=9100
ALLOY_PORT=12345

# --- Discord Webhook for Alerts ---
# Create: Discord Server Settings -> Integrations -> Webhooks -> New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME

# --- Generic Webhook (optional, alternative to Discord) ---
GENERIC_WEBHOOK_URL=

# --- Hostname label for metrics/logs ---
HOSTNAME=homelab
