# =============================================================================
# Homelab Stack Environment Variables
# =============================================================================
# Generate secrets with: openssl rand -base64 32
# Timezone
TZ=Asia/Jakarta

# =============================================================================
# 1-Proxy Layer (Nginx Proxy Manager + MariaDB)
# =============================================================================
# MariaDB
MARIADB_ROOT_PASSWORD=generate_with_openssl_rand_base64_32
MARIADB_DATABASE=proxymanager
MARIADB_USER=proxymanager
MARIADB_PASSWORD=generate_with_openssl_rand_base64_32

# Nginx Proxy Manager
NGINX_PROXY_MANAGER_EMAIL=admin@example.com
NGINX_PROXY_MANAGER_PASSWORD=generate_strong_password

# Domain names for proxy services
NGINX_PROXY_MANAGER_DOMAIN=proxy.example.com
GRAFANA_DOMAIN=monitoring.example.com
LOKI_DOMAIN=logs.example.com
TEMPO_DOMAIN=traces.example.com
GIT_DOMAIN=git.example.com
INFISCAL_DOMAIN=secrets.example.com
PORTAINER_DOMAIN=portainer.example.com
WOODPECKER_DOMAIN=ci.example.com
VAULTWARDEN_DOMAIN=secrets.example.com
NTFY_DOMAIN=ntfy.example.com
VIKUNJA_DOMAIN=tasks.example.com

# =============================================================================
# 2-Orchestration Layer (Portainer)
# =============================================================================
# Portainer
PORTAINER_ADMIN_PASSWORD=generate_strong_password
PORTAINER_SECRET=generate_with_openssl_rand_base64_32

# =============================================================================
# 3-Secrets Layer (Gitea + Infisical)
# =============================================================================
# Gitea
GIT_ROOT_PASSWORD=generate_with_openssl_rand_base64_32
GIT_DOMAIN=git.example.com
GIT_ROOT_EMAIL=admin@example.com

# Gitea PostgreSQL
GIT_POSTGRES_HOST=postgres-database
GIT_POSTGRES_PORT=5432
GIT_POSTGRES_USER=gitea
GIT_POSTGRES_PASSWORD=generate_with_openssl_rand_base64_32
GIT_POSTGRES_DATABASE=gitea

# Infisical
INFISCAL_SECRET_KEY=generate_with_openssl_rand_base64_32
INFISCAL_DATABASE_URL=postgresql://infisical:generate_password@postgres-database:5432/infisical?sslmode=prefer
INFISCAL_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32

# Infisical PostgreSQL
INFISCAL_POSTGRES_HOST=postgres-database
INFISCAL_POSTGRES_PORT=5432
INFISCAL_POSTGRES_USER=infisical
INFISCAL_POSTGRES_PASSWORD=generate_with_openssl_rand_base64_32
INFISCAL_POSTGRES_DATABASE=infisical

# =============================================================================
# 4-Monitoring Layer (Prometheus + Grafana + Uptime Kuma + Alertmanager + node-exporter + cAdvisor)
# =============================================================================
# Prometheus
PROMETHEUS_CONFIG_FILE=/etc/prometheus/config/prometheus.yml
PROMETHEUS_STORAGE_PATH=/data

# Grafana
GF_SECURITY_ADMIN_PASSWORD=generate_strong_password
GF_USERS_ALLOW_SIGN_UP=false
GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource,grafana-piechart-panel

# Alertmanager
ALERTMANAGER_TELEGRAM_BOT_TOKEN=generate_telegram_bot_token
ALERTMANAGER_TELEGRAM_CHAT_ID=telegram_chat_id

# Uptime Kuma
UPTIME_KUMA_EMAIL=admin@example.com
UPTIME_KUMA_PASSWORD=generate_strong_password

# =============================================================================
# 5-Logging Layer (Loki + Promtail + Tempo)
# =============================================================================
# Loki
LOKI_RULER_STORAGE_PATH=/data/loki-ruler
LOKI_TSDB_DIR=/data/tsdb
LOKI_MEMBERLIST_PORT=7946

# Promtail
PROMTAIL_CONFIG_FILE=/etc/promtail/config.yml

# Tempo
TEMPO_STORAGE_PATH=/data/tempo
TEMPO_MEMBERLIST_PORT=7946

# =============================================================================
# 6-Database Layer (Shared PostgreSQL + Redis)
# =============================================================================
# Shared PostgreSQL
POSTGRES_PASSWORD=generate_with_openssl_rand_base64_32
POSTGRES_USER=homelab
POSTGRES_DATABASE=homelab

# Redis
REDIS_PASSWORD=generate_strong_password
REDIS_HOST=redis

# =============================================================================
# 7-Backup Layer (Restic with rclone)
# =============================================================================
# Restic
RESTIC_REPOSITORY=s3:https://s3.us-east-1.backblazeb2.com/bucket-name
RESTIC_PASSWORD=generate_strong_password_for_backups
AWS_ACCESS_KEY_ID=backblaze_access_key
AWS_SECRET_ACCESS_KEY=backblaze_secret_key
RCLONE_CONFIG=backblazeb2
B2_ACCOUNT_ID=backblaze_account_id
B2_ACCOUNT_KEY=backblaze_account_key

# =============================================================================
# 8-CICD Layer (Woodpecker Server + Agent)
# =============================================================================
# Woodpecker Server
WOODPECKER_AGENT_SECRET=generate_with_openssl_rand_base64_32
WOODPECKER_DATABASE_DRIVER=postgres
WOODPECKER_DATABASE_DATASOURCE=postgresql://woodpecker:generate_password@postgres-database:5432/woodpecker?sslmode=prefer

# Woodpecker Agent
WOODPECKER_SERVER=woodpecker:9000
WOODPECKER_AGENT_SECRET=generate_with_openssl_rand_base64_32

# Woodpecker PostgreSQL
WOODPECKER_POSTGRES_HOST=postgres-database
WOODPECKER_POSTGRES_PORT=5432
WOODPECKER_POSTGRES_USER=woodpecker
WOODPECKER_POSTGRES_PASSWORD=generate_with_openssl_rand_base64_32
WOODPECKER_POSTGRES_DATABASE=woodpecker

# =============================================================================
# 9-Ops Layer (Ntfy + Vaultwarden + Vikunja)
# =============================================================================
# Ntfy
NTFY_ENABLE_SIGNUP=false
NTFY_SMTP_HOST=
NTFY_SMTP_PORT=587
NTFY_SMTP_USERNAME=
NTFY_SMTP_PASSWORD=
NTFY_SMTP_FROM_EMAIL=admin@example.com

# Vaultwarden
VAULTWARDEN_ADMIN_TOKEN=generate_with_openssl_rand_base64_32
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_DOMAIN=https://secrets.example.com

# Vikunja
VIKUNJA_DATABASE_URL=postgresql://vikunja:generate_password@postgres-database:5432/vikunja?sslmode=prefer
VIKUNJA_SECRET_KEY=generate_with_openssl_rand_base64_32
VIKUNJA_SERVICE_JWT_SECRET=generate_with_openssl_rand_base64_32