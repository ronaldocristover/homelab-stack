# ── Server connections ─────────────────────────────────────────────
# Multi-server config is defined in servers.json (or servers.prod.json).
# See servers.json.example for format. DB_SERVER/DB_PORT/DB_USER/DB_PASS/DB_NAMES
# are no longer used — all connection info lives in the JSON file.

# ── General ────────────────────────────────────────────────────────
DB_CLEANUP=true
CLEANUP_TIME=604800
TZ=UTC

# ── DigitalOcean Spaces (S3) ───────────────────────────────────────
DO_ACCESS_KEY=
DO_SECRET_KEY=
DO_ENDPOINT=nyc3.digitaloceanspaces.com
DO_REGION=nyc3
DO_BUCKET=my-backup-bucket
DO_PATH=mysql
# DO_PATH is the default S3 prefix. Each server in servers.json can
# override this with an optional "s3_path" field.
DO_CLEANUP=true
DO_CLEANUP_DAYS=30

# ── Local HDD backup (secondary local destination) ─────────────────
LOCAL_BACKUP_ENABLED=true
HDD_MOUNT_PATH=/mnt/hdd/mysql-backups
LOCAL_CLEANUP=true
LOCAL_CLEANUP_DAYS=90

# ── Failure alerts (Slack/Discord/generic HTTP webhook) ────────────
ALERT_WEBHOOK_URL=
ALERT_HOSTNAME=

# ── Discord GIF per status ─────────────────────────────────────────
GIF_URL_SUCCESS=https://i.pinimg.com/originals/e9/38/d1/e938d18fc07a3ffd16b4864ef2f1308f.gif
GIF_URL_WARNING=https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExZ3dsYTU4NWRqN2kwOXB6dmZ0eWRtYzg2eDRvcHVtaGR5bXlpMnV3aSZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/dJYoOVAWf2QkU/giphy.gif
GIF_URL_FAILURE=https://media4.giphy.com/media/v1.Y2lkPTc5MGI3NjExNGk3YjczeDdjZWl1ajM2cDRvNGp0cTZydHBxeG5mNWRvcWZpNTdsNCZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9Zw/gpSFX1H4Y73ciMEWAf/giphy.gif
